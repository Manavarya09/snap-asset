{
  "name": "@masyv/snap-asset",
  "version": "0.1.0",
  "description": "Capture web screenshots & extract site assets as optimized PNG+WebP — CLI + Claude Code skill",
  "type": "module",
  "bin": {
    "snap-asset": "./bin/snap-asset.js"
  },
  "main": "src/index.js",
  "scripts": {
    "postinstall": "npx playwright install chromium --with-deps 2>/dev/null || npx playwright install chromium",
    "test": "node --test tests/*.test.js",
    "start": "node bin/snap-asset.js"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "screenshot",
    "playwright",
    "webp",
    "assets",
